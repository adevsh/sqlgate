# sqlgate environment variables
# Copy this file to .env and fill in the values.

# HTTP server listen address (default: 0.0.0.0:8080)
LISTEN_ADDR=0.0.0.0:8080

DATABASE_URL=postgres://sqlgate:sqlgate@localhost:5432/sqlgate

# Cloudflare Access tunnel shared-secret header.
# The header name is configurable; the value must match what cloudflared
# injects into every proxied request. Requests without this header are
# rejected as having bypassed the tunnel.
CF_TUNNEL_SECRET_HEADER=X-CF-Tunnel-Secret
CF_TUNNEL_SECRET_VALUE=changeme

# -- Target database connection strings (per-database, per-role) --
#
# These map to the docker-compose services. Default credentials match
# docker/init-target-{pg,my}.sql.

# Postgres target — preview role (read-only, port 5433)
TARGET_sample_pg_PREVIEW=postgres://sqlgate_preview:preview@localhost:5433/sample_pg

# Postgres target — execute role (read-write)
TARGET_sample_pg_EXECUTE=postgres://sqlgate_execute:execute@localhost:5433/sample_pg

# MySQL target — preview role (read-only, port 3306)
TARGET_sample_my_PREVIEW=mysql://sqlgate_preview:preview@localhost:3306/sample_my

# MySQL target — execute role (read-write)
TARGET_sample_my_EXECUTE=mysql://sqlgate_execute:execute@localhost:3306/sample_my

# Approval TTL in seconds (default: 900 = 15 minutes)
APPROVAL_TTL_SECONDS=900

# Maximum query text length in bytes (default: 65536)
MAX_QUERY_LENGTH=65536
