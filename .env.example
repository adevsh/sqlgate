# sqlgate environment variables
# Copy this file to .env and fill in the values.

# HTTP server listen address (default: 0.0.0.0:8080)
LISTEN_ADDR=0.0.0.0:8080

# Postgres persistence database (stores requests, approvals, audit log)
DATABASE_URL=postgres://sqlgate:changeme@localhost:5432/sqlgate

# Cloudflare Access tunnel shared-secret header.
# The header name is configurable; the value must match what cloudflared
# injects into every proxied request. Requests without this header are
# rejected as having bypassed the tunnel.
CF_TUNNEL_SECRET_HEADER=X-CF-Tunnel-Secret
CF_TUNNEL_SECRET_VALUE=changeme

# -- Target database connection strings (per-database, per-role) --

# Preview role (read-only, used for query previews)
# Format: TARGET_<DBNAME>_PREVIEW=postgres://sqlgate_preview:...@host:port/dbname
# TARGET_mydb_PREVIEW=postgres://sqlgate_preview:changeme@localhost:5432/mydb

# Execute role (read-write, used to execute approved queries)
# TARGET_mydb_EXECUTE=postgres://sqlgate_execute:changeme@localhost:5432/mydb

# Replica endpoint (optional, used when target_topology=replica)
# TARGET_mydb_REPLICA=postgres://sqlgate_preview:changeme@replica-host:5432/mydb

# -- MySQL target (same pattern, different scheme) --
# TARGET_mydb_PREVIEW=mysql://sqlgate_preview:changeme@localhost:3306/mydb
# TARGET_mydb_EXECUTE=mysql://sqlgate_execute:changeme@localhost:3306/mydb

# Approval TTL in seconds (default: 900 = 15 minutes)
APPROVAL_TTL_SECONDS=900

# Maximum query text length in bytes (default: 65536)
MAX_QUERY_LENGTH=65536
